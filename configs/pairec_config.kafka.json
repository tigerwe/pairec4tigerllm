{
  "_comment": "PaiRec 配置 - Kafka 实时特征模式",
  
  "RunMode": "daily",
  "ListenConf": {
    "HttpAddr": "0.0.0.0",
    "HttpPort": 18080
  },
  "SceneConfs": {
    "home_feed": {
      "RecallNames": ["generative_recall"],
      "SortNames": ["boost_score_sort"]
    }
  },
  "RecallConfs": [
    {
      "Name": "generative_recall",
      "RecallType": "GenerativeRecall",
      "RecallCount": 50,
      "CacheTime": 60,
      "CachePrefix": "gen_recall_",
      "RecallAlgo": "{\"server_url\":\"http://localhost:8000\",\"topk\":10,\"temperature\":1.0,\"beam_width\":1,\"history_from\":\"user_feature\",\"history_feature_name\":\"click_history\",\"history_delimiter\":\",\",\"history_max_length\":20,\"feature_source\":\"kafka\",\"kafka_config\":{\"brokers\":[\"localhost:9092\"],\"topic\":\"user-features\",\"group_id\":\"pairec-generative\"}}"
    }
  ],
  "SortConfs": [
    {
      "Name": "boost_score_sort",
      "SortType": "BoostScoreSort"
    }
  ]
}
