{
  "app": {
    "name": "pairec4tigerllm",
    "version": "1.0.0",
    "port": 8080,
    "debug": true
  },
  "recall": {
    "generative_recall": {
      "type": "GenerativeRecall",
      "model_name": "generative_recall",
      "recall_count": 50,
      "cache_adapter": "local",
      "cache_time": 300,
      "cache_prefix": "gen_recall_",
      "tiger_recall_conf": {
        "tiger_name": "http://localhost:8000",
        "top_k": 50,
        "temperature": 1.0,
        "beam_width": 1,
        "history_from": "user_feature",
        "history_feature_name": "click_history",
        "history_delimiter": ",",
        "history_max_length": 20
      }
    },
    "mock_recall": {
      "type": "MockRecall",
      "model_name": "mock_recall",
      "recall_count": 100
    }
  },
  "rank": {
    "general_rank": {
      "type": "GeneralRank",
      "model_name": "general_rank",
      "rank_count": 100
    }
  },
  "sort": {
    "boost_score_sort": {
      "type": "BoostScoreSort",
      "model_name": "boost_score_sort"
    }
  },
  "datasource": {
    "user_feature": {
      "type": "file",
      "path": "./data/user_features.json"
    }
  }
}
